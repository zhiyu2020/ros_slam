    <!-- <model name="right_box">
      <static>true</static>
      <pose>1.2 -1.0 0.2 0 0 -0.2</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.8 0.4</size></box></geometry>
